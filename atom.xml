    <title>PythonзҲ¬иҷ«з»ғд№ -д»Ҡж—ҘеӨҙжқЎ-иЎ—жӢҚ-001</title>
    <link href="http://yoursite.com/2019/04/08/Python%E7%88%AC%E8%99%AB%E7%BB%83%E4%B9%A0-%E4%BB%8A%E6%97%A5%E5%A4%B4%E6%9D%A1-%E8%A1%97%E6%8B%8D-001/"/>
    <id>http://yoursite.com/2019/04/08/PythonзҲ¬иҷ«з»ғд№ -д»Ҡж—ҘеӨҙжқЎ-иЎ—жӢҚ-001/</id>
    <published>2019-04-08T12:33:18.000Z</published>
    <updated>2019-04-11T12:38:07.645Z</updated>
    
    <content type="html"><![CDATA[<h1 id="PythonзҲ¬иҷ«з»ғд№ -д»Ҡж—ҘеӨҙжқЎ-иЎ—жӢҚ-001"><a href="#PythonзҲ¬иҷ«з»ғд№ -д»Ҡж—ҘеӨҙжқЎ-иЎ—жӢҚ-001" class="headerlink" title="PythonзҲ¬иҷ«з»ғд№ -д»Ҡж—ҘеӨҙжқЎ-иЎ—жӢҚ  -001"></a>PythonзҲ¬иҷ«з»ғд№ -<em>д»Ҡж—ҘеӨҙжқЎ-иЎ—жӢҚ</em>  -001</h1><figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br><span class="line">23</span><br><span class="line">24</span><br><span class="line">25</span><br><span class="line">26</span><br><span class="line">27</span><br><span class="line">28</span><br><span class="line">29</span><br><span class="line">30</span><br><span class="line">31</span><br><span class="line">32</span><br><span class="line">33</span><br><span class="line">34</span><br><span class="line">35</span><br><span class="line">36</span><br><span class="line">37</span><br><span class="line">38</span><br><span class="line">39</span><br><span class="line">40</span><br><span class="line">41</span><br><span class="line">42</span><br><span class="line">43</span><br><span class="line">44</span><br><span class="line">45</span><br><span class="line">46</span><br><span class="line">47</span><br><span class="line">48</span><br><span class="line">49</span><br><span class="line">50</span><br><span class="line">51</span><br><span class="line">52</span><br><span class="line">53</span><br><span class="line">54</span><br><span class="line">55</span><br><span class="line">56</span><br><span class="line">57</span><br><span class="line">58</span><br><span class="line">59</span><br><span class="line">60</span><br><span class="line">61</span><br><span class="line">62</span><br><span class="line">63</span><br><span class="line">64</span><br><span class="line">65</span><br><span class="line">66</span><br><span class="line">67</span><br><span class="line">68</span><br><span class="line">69</span><br><span class="line">70</span><br><span class="line">71</span><br><span class="line">72</span><br><span class="line">73</span><br><span class="line">74</span><br><span class="line">75</span><br><span class="line">76</span><br><span class="line">77</span><br><span class="line">78</span><br><span class="line">79</span><br><span class="line">80</span><br><span class="line">81</span><br><span class="line">82</span><br><span class="line">83</span><br><span class="line">84</span><br><span class="line">85</span><br><span class="line">86</span><br><span class="line">87</span><br><span class="line">88</span><br><span class="line">89</span><br><span class="line">90</span><br><span class="line">91</span><br><span class="line">92</span><br><span class="line">93</span><br><span class="line">94</span><br><span class="line">95</span><br></pre></td><td class="code"><pre><span class="line">import os</span><br><span class="line">import re</span><br><span class="line">from hashlib import md5</span><br><span class="line">from multiprocessing.pool import Pool</span><br><span class="line">import requests</span><br><span class="line">from urllib.parse import urlencode</span><br><span class="line">from requests import codes</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">def get_page(offset):</span><br><span class="line">    params = &#123;</span><br><span class="line">        &apos;aid&apos;: &apos;24&apos;,</span><br><span class="line">        &apos;app_name&apos;: &apos;web_search&apos;,</span><br><span class="line">        &apos;offset&apos;: offset,</span><br><span class="line">        &apos;format&apos;: &apos;json&apos;,</span><br><span class="line">        # &apos;keyword&apos;: &apos;иЎ—жӢҚ&apos;,</span><br><span class="line">        &apos;autoload&apos;: &apos;true&apos;,</span><br><span class="line">        &apos;count&apos;: &apos;20&apos;,</span><br><span class="line">        &apos;en_qc&apos;: &apos;1&apos;,</span><br><span class="line">        &apos;cur_tab&apos;: &apos;1&apos;,</span><br><span class="line">        &apos;from&apos;: &apos;search_tab&apos;,</span><br><span class="line">        &apos;pd&apos;: &apos;synthesis&apos;,</span><br><span class="line">        # &apos;timestamp&apos;: timestamp</span><br><span class="line">    &#125;</span><br><span class="line">    # дҪҝз”Ёurlencodeе°ҶparamеҸӮж•°иҪ¬жҚўдёәurlеҪўејҸ</span><br><span class="line">    url = &apos;https://www.toutiao.com/api/search/content/?keyword=%E8%A1%97%E6%8B%8D&apos; + urlencode(params)</span><br><span class="line">    try:</span><br><span class="line">        resp = requests.get(url)</span><br><span class="line">        print(url)</span><br><span class="line">        if resp.status_code == codes.ok:</span><br><span class="line">            # иҝ”еӣһж•°жҚ®зұ»еһӢдёәjsonзұ»еһӢ</span><br><span class="line">            return resp.json()</span><br><span class="line">    except requests.ConnectionError:</span><br><span class="line">        return None</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">def get_images(json):</span><br><span class="line">    if json.get(&apos;data&apos;):</span><br><span class="line">        data = json.get(&apos;data&apos;)</span><br><span class="line">        for item in data:</span><br><span class="line">            # и§ӮеҜҹjsonж•°жҚ®еҸҜеҫ—зҹҘеҪ“dataдёӯж— cell_typeж—¶пјҢж•°жҚ®жүҚжҳҜжӯЈзЎ®зҡ„</span><br><span class="line">            if item.get(&apos;cell_type&apos;) is not None:</span><br><span class="line">                continue</span><br><span class="line">            title = item.get(&apos;title&apos;)</span><br><span class="line">            images = item.get(&apos;image_list&apos;)</span><br><span class="line">            for image in images:</span><br><span class="line">                # иҜҘжӯЈеҲҷиЎЁиҫҫж„ҸжҖқдёәпјҡе°Ҷurlдёӯзҡ„listе…ЁйғЁеӨ©е№»дёәorigin</span><br><span class="line">                origin_image = re.sub(&quot;list&quot;, &quot;origin&quot;, image.get(&apos;url&apos;))</span><br><span class="line">                yield &#123;</span><br><span class="line">                    &apos;image_url&apos;: origin_image,</span><br><span class="line">                    &apos;title&apos;: title</span><br><span class="line">                &#125;</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">def save_images(item):</span><br><span class="line">    # и®ҫзҪ®imageж”ҫзҪ®жүҖеңЁзӣ®еҪ•дҪҚзҪ®пјҢз¬¬дәҢдёӘд»ЈиЎЁж–ңзәҝ/</span><br><span class="line">    img_path = &apos;img&apos; + os.path.sep + item.get(&apos;title&apos;)</span><br><span class="line">    # еҰӮжһңиҜҘзӣ®еҪ•дёҚеӯҳеңЁпјҢеҲҷеҲӣе»ә</span><br><span class="line">    if not os.path.exists(img_path):</span><br><span class="line">        # дҪҝз”Ёos.makedirsжқҘиҝӣиЎҢйҖ’еҪ’еҲӣе»әж–Үд»¶еӨ№</span><br><span class="line">        os.makedirs(img_path)</span><br><span class="line">    try:</span><br><span class="line">        resp = requests.get(item.get(&apos;image_url&apos;))</span><br><span class="line">        if resp.status_code == codes.ok:</span><br><span class="line">            # imageеҶҷе…Ҙең°еқҖпјҢдҪҝз”Ёж–Үд»¶зҡ„md5еҖјз”ЁжқҘдҪңдёәж–Үд»¶еҗҚпјҢдҝқиҜҒдёҚдјҡдёӢиҪҪеҲ°йҮҚеӨҚзҡ„ж–Үд»¶</span><br><span class="line">            file_path = img_path + os.path.sep + &apos;&#123;file_name&#125;.&#123;file_suffix&#125;&apos;.format(</span><br><span class="line">                file_name=md5(resp.content).hexdigest(),</span><br><span class="line">                file_suffix=&apos;jpg&apos;)</span><br><span class="line">            # еҰӮиӢҘж–Үд»¶дёҚеӯҳеңЁ</span><br><span class="line">            if not os.path.exists(file_path):</span><br><span class="line">                # еҲҷд»ҘдәҢиҝӣеҲ¶ж јејҸеҶҷе…Ҙ</span><br><span class="line">                with open(file_path, &apos;wb&apos;) as fb:</span><br><span class="line">                    fb.write(resp.content)</span><br><span class="line">                print(&apos;дёӢиҪҪж–Үд»¶ең°еқҖдёәпјҡ %s&apos; % file_path)</span><br><span class="line">            else:</span><br><span class="line">                print(&apos;иҜҘж–Үд»¶е·ІдёӢиҪҪ&apos;, file_path)</span><br><span class="line">    except requests.ConnectionError():</span><br><span class="line">        print(&apos;е°қиҜ•дҝқеӯҳimagesеҮәй”ҷ&apos;)</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">def main(offset):</span><br><span class="line">    json = get_page(offset)</span><br><span class="line">    for item in get_images(json):</span><br><span class="line">        print(item)</span><br><span class="line">        save_images(item)</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">GROUP_START = 0</span><br><span class="line">GROUP_END = 3</span><br><span class="line">if __name__ == &apos;__main__&apos;:</span><br><span class="line">    pool = Pool()</span><br><span class="line">    groups = ([x * 20 for x in range(GROUP_START, GROUP_END + 1)])</span><br><span class="line">    pool.map(main, groups)</span><br><span class="line">    pool.close()</span><br><span class="line">    pool.join()</span><br></pre></td></tr></table></figure>]]></content>
    
